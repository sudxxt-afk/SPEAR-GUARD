# Database Configuration
POSTGRES_DB=spearguard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/spearguard

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_TIMEOUT=30

# Application Settings
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ENCRYPTION_KEY=  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENVIRONMENT=development
DEBUG=True

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# JWT Settings
JWT_SECRET_KEY=change-this-jwt-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@spear-guard.gov.ru
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@spear-guard.gov.ru
SMTP_FROM_NAME=SPEAR-GUARD

# Security Settings
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_SPECIAL=True
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Analysis Engine Settings
QUICK_ANALYSIS_TIMEOUT=2
FULL_ANALYSIS_TIMEOUT=10
DEFAULT_CACHE_TTL=900
REGISTRY_CACHE_TTL=3600

# Threat Intelligence
THREAT_INTEL_UPDATE_INTERVAL=3600
BLACKLIST_THRESHOLD=3

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=1000

# Celery Configuration (for background tasks)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/spearguard.log

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Machine Learning Models
ML_MODEL_PATH=/app/models
ML_MODEL_VERSION=1.0.0

# Monitoring & Metrics
ENABLE_METRICS=True
METRICS_PORT=9090

# Feature Flags
ENABLE_BROWSER_EXTENSION=True
ENABLE_EMAIL_FORWARDING=True
ENABLE_THREAT_INTEL=True
ENABLE_SANDBOX_ANALYSIS=False
